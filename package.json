{
  "name": "citrusstacks-sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for milestone-journal Clarity contract interactions on Stacks.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:utils": "vitest run test/client.test.ts",
    "test:vault": "vitest run test/client.test.ts",
    "test:constants": "vitest run test/client.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "stacks",
    "clarity",
    "milestone",
    "attestation",
    "sdk",
    "web3"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/realvic22/citrus-forge-sdk"
  },
  "dependencies": {
    "@stacks/transactions": "^7.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
